generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  DRIVER
  ADMIN
}

enum TicketStatus {
  PENDING
  PAID
  USED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  firstName   String
  lastName    String
  phone       String?   @unique
  role        Role      @default(USER)
  isVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  driverBus   Bus?      @relation("DriverToBus")
  tickets     Ticket[]
  payments    Payment[]

  @@map("users")
}

model Line {
  id          Int      @id @default(autoincrement())
  name        String   @unique // ex: "Ligne 1", "Ligne A"
  number      String   @unique // ex: "1", "A", "BRT1"
  color       String?  // couleur de la ligne pour l'affichage
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  buses       Bus[]
  routes      Route[]

  @@map("lines")
}

model Bus {
  id               String        @id @default(cuid())
  busNumber        String        @unique // numéro du bus (ex: "001", "A12")
  licensePlate     String        @unique
  capacity         Int
  model            String?
  year             Int?
  lineId           Int?          // ligne à laquelle le bus est assigné
  driverId         String        @unique
  isActive         Boolean       @default(true)
  passengersCount  Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  line             Line?         @relation(fields: [lineId], references: [id])
  driver           User          @relation("DriverToBus", fields: [driverId], references: [id])
  currentPosition  Position?
  trips            Trip[]

  @@map("buses")
}

model Position {
  id        Int      @id @default(autoincrement())
  busId     String      @unique
  latitude  Float
  longitude Float
  altitude  Float?
  speed     Float?
  heading   Float?
  timestamp DateTime @default(now())

  // Relations
  bus       Bus      @relation(fields: [busId], references: [id], onDelete: Cascade)

  @@map("positions")
}

model Route {
  id            Int      @id @default(autoincrement())
  name          String
  lineId        Int?     // route appartient à une ligne
  startPointId  Int?
  endPointId    Int?
  distance      Float?   // calculé automatiquement en km
  duration      Int?     // calculé automatiquement en minutes
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  line          Line?       @relation(fields: [lineId], references: [id])
  startPoint    RoutePoint? @relation("RouteStartPoint", fields: [startPointId], references: [id])
  endPoint      RoutePoint? @relation("RouteEndPoint", fields: [endPointId], references: [id])
  trips         Trip[]
  points        RoutePoint[] @relation("RoutePoints")

  @@map("routes")
}

model RoutePoint {
  id        Int      @id @default(autoincrement())
  routeId   Int
  latitude  Float
  longitude Float
  elevation Float?
  seq       Int      // ordre du point dans la route (commence à 1)
  name      String?  // nom optionnel du point (ex: "Arrêt Central")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  route         Route  @relation("RoutePoints", fields: [routeId], references: [id], onDelete: Cascade)
  routeAsStart  Route[] @relation("RouteStartPoint")
  routeAsEnd    Route[] @relation("RouteEndPoint")

  @@unique([routeId, seq])
  @@map("route_points")
}

model Trip {
  id            Int        @id @default(autoincrement())
  routeId       Int
  busId         String
  startTime     DateTime
  endTime       DateTime?
  price         Float
  availableSeats Int
  status        TripStatus @default(SCHEDULED)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  route         Route      @relation(fields: [routeId], references: [id])
  bus           Bus        @relation(fields: [busId], references: [id])
  tickets       Ticket[]

  @@map("trips")
}

model Ticket {
  id            Int          @id @default(autoincrement())
  userId        String
  tripId        Int
  seatNumber    String?
  qrCode        String       @unique
  status        TicketStatus @default(PENDING)
  purchaseDate  DateTime     @default(now())
  validUntil    DateTime?
  usedAt        DateTime?

  // Relations
  user          User         @relation(fields: [userId], references: [id])
  trip          Trip         @relation(fields: [tripId], references: [id])
  payment       Payment?

  @@map("tickets")
}

model Payment {
  id                Int           @id @default(autoincrement())
  ticketId          Int           @unique
  userId            String
  amount            Float
  currency          String        @default("FCFA")
  paydunyaToken     String?       @unique
  paydunyaReference String?
  status            PaymentStatus @default(PENDING)
  paymentMethod     String?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  ticket            Ticket        @relation(fields: [ticketId], references: [id])
  user              User          @relation(fields: [userId], references: [id])

  @@map("payments")
}
