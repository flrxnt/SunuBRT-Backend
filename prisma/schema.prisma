generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())

  email String @unique

  password String

  firstName String

  lastName String

  phone String? @unique

  role Role @default(USER)

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  driverBus Bus? @relation("DriverToBus")

  payments Payment[]

  adminRefunds Refund[] @relation("AdminRefunds")

  tickets Ticket[]

  validatedUsages TicketUsage[] @relation("UserValidatedUsages")

  @@map("users")
}

model Stop {
  id          Int      @id @default(autoincrement())
  name        String
  address     String?
  latitude    Float
  longitude   Float
  zone        String?
  services    Json?    // Array of services like ["wifi", "accessible", "shelter", "bench", "lighting"]
  photo       String?  // URL to photo
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  routePoints RoutePoint[] // Route points that correspond to this stop
  lines       Line[]       @relation("StopLines") // Lines that pass through this stop

  @@map("stops")
}

model Line {
  id            Int             @id @default(autoincrement())
  name          String          @unique
  number        String          @unique
  color         String?
  description   String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  buses         Bus[]
  routes        Route[]
  ticketPricing TicketPricing[]
  stops         Stop[]          @relation("StopLines") // Lines that pass through stops

  @@map("lines")
}

model Bus {
  id String @id @default(cuid())

  licensePlate String @unique

  capacity Int

  model String?

  year Int?

  driverId String @unique

  isActive Boolean @default(true)

  passengersCount Int @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  busNumber String @unique

  lineId Int?

  driver User @relation("DriverToBus", fields: [driverId], references: [id])

  line Line? @relation(fields: [lineId], references: [id])

  currentPosition Position?

  trips Trip[]

  usages TicketUsage[] @relation("BusUsages")

  @@map("buses")
}

model Position {
  id        Int      @id @default(autoincrement())
  busId     String   @unique
  latitude  Float
  longitude Float
  altitude  Float?
  speed     Float?
  heading   Float?
  timestamp DateTime @default(now())
  bus       Bus      @relation(fields: [busId], references: [id], onDelete: Cascade)

  @@map("positions")
}

model Route {
  id           Int          @id @default(autoincrement())
  name         String
  startPointId Int?
  endPointId   Int?
  distance     Float?
  duration     Int?
  description  String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  lineId       Int?
  points       RoutePoint[] @relation("RoutePoints")
  endPoint     RoutePoint?  @relation("RouteEndPoint", fields: [endPointId], references: [id])
  line         Line?        @relation(fields: [lineId], references: [id])
  startPoint   RoutePoint?  @relation("RouteStartPoint", fields: [startPointId], references: [id])

  ticketPricing TicketPricing[]

  trips Trip[]

  usages TicketUsage[] @relation("RouteUsages")

  @@map("routes")
}

model RoutePoint {
  id           Int      @id @default(autoincrement())
  routeId      Int
  stopId       Int?     // Reference to physical stop
  latitude     Float
  longitude    Float
  elevation    Float?
  seq          Int
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  route        Route    @relation("RoutePoints", fields: [routeId], references: [id], onDelete: Cascade)
  routeAsEnd   Route[]  @relation("RouteEndPoint")
  routeAsStart Route[]  @relation("RouteStartPoint")
  stop         Stop?    @relation(fields: [stopId], references: [id])

  @@unique([routeId, seq])
  @@map("route_points")
}

model Trip {
  id             Int        @id @default(autoincrement())
  routeId        Int
  busId          String
  startTime      DateTime
  endTime        DateTime?
  price          Float
  availableSeats Int
  status         TripStatus @default(SCHEDULED)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tickets Ticket[]

  bus Bus @relation(fields: [busId], references: [id])

  route Route @relation(fields: [routeId], references: [id])

  usages TicketUsage[] @relation("TripUsages")

  @@map("trips")
}

model Ticket {
  id                 Int            @id @default(autoincrement())
  userId             String
  tripId             Int?
  seatNumber         String?
  qrCode             String         @unique
  status             TicketStatus   @default(PENDING)
  purchaseDate       DateTime       @default(now())
  validFrom          DateTime?
  validUntil         DateTime?
  usedAt             DateTime?
  cancellationReason String?
  cancelledAt        DateTime?
  notes              String?
  passengers         Int            @default(1)
  pricingId          Int?
  validationLocation String?
  validationNotes    String?
  ticketType         TicketType     @default(SINGLE_USE)
  isReusable         Boolean        @default(false)
  currentUsages      Int            @default(0)
  maxUsages          Int?
  payment            Payment?
  pricing            TicketPricing? @relation(fields: [pricingId], references: [id])
  trip               Trip?          @relation(fields: [tripId], references: [id])
  user               User           @relation(fields: [userId], references: [id])
  usages             TicketUsage[]  @relation("TicketUsages")

  @@map("tickets")
}

model TicketUsage {
  id          Int      @id @default(autoincrement())
  ticketId    Int
  tripId      Int?
  busId       String?
  validatorId String?
  routeId     Int?
  usedAt      DateTime @default(now())
  latitude    Float?
  longitude   Float?
  notes       String?

  ticket Ticket @relation("TicketUsages", fields: [ticketId], references: [id], onDelete: Cascade)

  trip Trip? @relation("TripUsages", fields: [tripId], references: [id])

  bus Bus? @relation("BusUsages", fields: [busId], references: [id])

  validator User? @relation("UserValidatedUsages", fields: [validatorId], references: [id])

  route Route? @relation("RouteUsages", fields: [routeId], references: [id])

  @@map("ticket_usages")
}

model Payment {
  id                   Int           @id @default(autoincrement())
  ticketId             Int?          @unique
  userId               String
  amount               Float
  currency             String        @default("XOF")
  status               PaymentStatus @default(PENDING)
  paymentMethod        String?
  paidAt               DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  cancellationReason   String?
  cancelledAt          DateTime?
  customData           Json          @default("{}")
  customerEmail        String?
  customerName         String?
  customerPhone        String?
  discountAmount       Float         @default(0)
  externalData         Json          @default("{}")
  externalReference    String?
  externalToken        String?       @unique
  fees                 Float         @default(0)
  netAmount            Float?
  notes                String?
  originalAmount       Float?
  promoCode            String?
  provider             String        @default("PAYDUNYA")
  transactionReference String?
  ticket               Ticket?       @relation(fields: [ticketId], references: [id])
  user                 User          @relation(fields: [userId], references: [id])
  refunds              Refund[]

  @@map("payments")
}

model TicketPricing {
  id                 Int       @id @default(autoincrement())
  name               String
  type               String
  price              Float
  validityDuration   Int
  validityPeriodType String
  lineId             Int?
  routeId            Int?
  description        String?
  discountPercent    Float     @default(0)
  validFrom          DateTime?
  validTo            DateTime?
  isActive           Boolean   @default(true)
  maxTickets         Int?
  specialConditions  String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  line               Line?     @relation(fields: [lineId], references: [id])
  route              Route?    @relation(fields: [routeId], references: [id])
  tickets            Ticket[]

  @@map("ticket_pricing")
}

model Refund {
  id          Int       @id @default(autoincrement())
  paymentId   Int
  amount      Float
  reason      String
  adminNotes  String?
  adminUserId String
  status      String    @default("PENDING")
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  admin       User      @relation("AdminRefunds", fields: [adminUserId], references: [id])
  payment     Payment   @relation(fields: [paymentId], references: [id])

  @@map("refunds")
}

model PromoCode {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  name         String
  description  String?
  value        Float
  isPercentage Boolean   @default(false)
  maxUses      Int?
  currentUses  Int       @default(0)
  isActive     Boolean   @default(true)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("promo_codes")
}

enum Role {
  USER
  DRIVER
  ADMIN
}

enum TicketStatus {
  PENDING
  PAID
  USED
  CANCELLED
  EXPIRED
  ACTIVE
  SUSPENDED
}

enum TicketType {
  SINGLE_USE
  DAILY_PASS
  WEEKLY_PASS
  MONTHLY_PASS
  ANNUAL_PASS
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
